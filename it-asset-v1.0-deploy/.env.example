# IT运维管理系统 - 环境变量配置
# 复制此文件为 .env 并修改相应配置

# ============ Flask核心配置 ============
# 密钥（生产环境必须修改为随机字符串！）
# 生成方法: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-this-in-production

# Flask运行环境
# production: 生产环境
# development: 开发环境
FLASK_ENV=production

# ============ 数据库配置 ============
# SQLite数据库文件路径（相对路径或绝对路径）
DATABASE_PATH=asset.db

# ============ 日志配置 ============
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 日志文件路径（相对路径或绝对路径）
# 设置为 /dev/null 可禁用文件日志（仅使用systemd日志）
LOG_FILE=flask.log

# 日志文件最大大小（字节）
# 10485760 = 10MB
LOG_MAX_BYTES=10485760

# 日志文件保留数量
LOG_BACKUP_COUNT=5

# ============ 安全配置 ============
# Cookie安全设置（生产环境必须为True）
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# Session过期时间（秒）
# 86400 = 1天, 604800 = 7天
PERMANENT_SESSION_LIFETIME=86400

# ============ 管理员账号配置 ============
# 首次部署时的管理员密码
# 登录后请立即在"用户管理"中修改密码
# 密码要求: 至少8位，包含大小写字母和数字
ADMIN_PASSWORD=ChangeMe123!

# ============ 邮件配置（可选） ============
# 用于密码重置、告警通知等
# MAIL_SERVER=smtp.example.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your-email@example.com
# MAIL_PASSWORD=your-email-password
# MAIL_DEFAULT_SENDER=your-email@example.com

# ============ 告警配置（可选） ============
# 告警阈值设置
# ALERT_CPU_THRESHOLD=80
# ALERT_MEMORY_THRESHOLD=80
# ALERT_DISK_THRESHOLD=80

# ============ 备份配置 ============
# 自动备份设置
# BACKUP_ENABLED=True
# BACKUP_TIME=02:00
# BACKUP_RETENTION_DAYS=30
# BACKUP_DIR=/opt/it-ops/backups

# ============ 性能配置 ============
# Gunicorn工作进程数（建议: 2 * CPU核心数 + 1）
GUNICORN_WORKERS=4

# Gunicorn绑定地址
GUNICORN_BIND=127.0.0.1:5003

# 上传文件大小限制（字节）
# 10485760 = 10MB
MAX_CONTENT_LENGTH=10485760

# ============ 其他配置 ============
# 时区设置
TZ=Asia/Shanghai

# 语言设置
LANGUAGE=zh-CN
